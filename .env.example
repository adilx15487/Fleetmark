# ── Fleetmark Frontend Environment (Template) ──
# Copy this file to .env and fill in your values

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=

# Toggle mock data fallback
VITE_USE_MOCK=true

# Dev bypass — auto-login without 42 OAuth (local dev only)
VITE_DEV_BYPASS_AUTH=false

# 42 OAuth credentials
VITE_42_CLIENT_ID=your_42_client_id_here
VITE_42_REDIRECT_URI=http://localhost:5173/auth/callback

# Feature flags
VITE_NOTIFICATIONS_ENABLED=false
VITE_SCHEDULE_ENABLED=false
VITE_REPORTS_ENABLED=false
VITE_STOPS_API_ENABLED=false
