# ── Fleetmark Frontend Environment ──

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Toggle mock data fallback (set to "true" to skip real API)
VITE_USE_MOCK=false

# 42 OAuth
VITE_42_CLIENT_ID=<your_42_client_id>
VITE_42_REDIRECT_URI=https://fleetmark.vercel.app/auth/callback
